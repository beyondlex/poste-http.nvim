# @connection redis://127.0.0.1:6379

### Set string
SET mykey "hello world"

### Get string
GET mykey

### Set JSON
SET user:1 '{"name":"Tom","age":18,"tags":["redis","cache"]}'

### Get JSON
GET user:1

### Set hash
HSET user:2 name "Alice" age 25 city "Tokyo"

### Get all hash fields
HGETALL user:2

### Set list
RPUSH mylist "item1" "item2" "item3"

### Get list
LRANGE mylist 0 -1

### Set sorted set
ZADD leaderboard 100 "alice" 85 "bob" 92 "charlie"

### Get sorted set
ZRANGE leaderboard 0 -1 WITHSCORES
