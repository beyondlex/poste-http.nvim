{
  "name": "tree-sitter-poste-http",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Poste HTTP request files (.http, .rest)",
  "main": "grammar.js",
  "scripts": {
    "build": "tree-sitter build --wasm",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "tree-sitter": [
    {
      "scope": "source.poste_http",
      "file-types": ["http", "rest"],
      "injection-regex": "poste_http"
    }
  ]
}